# ─────────────────────────────────────────────
# JobRadar – Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production

# Host-Port für docker-compose (Standard: 3000)
HOST_PORT=3000

# Ollama KI-Backend
# Standard für lokale Docker-Netzwerke: http://host.docker.internal:11434
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# Web Push Benachrichtigungen (optional)
# Generieren mit: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:deine@email.de
