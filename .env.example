PORT=3000
DB_PATH=./data/bewerbungen.sqlite

# Ollama KI – Standard: http://localhost:11434
# Aendern wenn Ollama auf einem anderen Host laeuft (z.B. http://192.168.178.x:11434)
OLLAMA_URL=
OLLAMA_MODEL=mistral

# Adzuna (kostenlos, Key unter https://developer.adzuna.com)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Jooble (kostenlos, Key unter https://jooble.org/api/about)
JOOBLE_API_KEY=
