{
  "name": "jobradar",
  "version": "2.0.0",
  "description": "Vollst\u00e4ndig lokaler KI-Bewerbungsassistent mit Ollama, SQLite und PWA",
  "main": "src/index.js",
  "scripts": {
    "start":       "node src/index.js",
    "dev":         "nodemon src/index.js",
    "test":        "node --test tests/services/*.test.js",
    "test:api":    "node --test tests/api/*.test.js",
    "test:all":    "node --test tests/**/*.test.js",
    "migrate":     "node -e \"require('./src/db/database')\"",
    "lint":        "eslint src/"
  },
  "dependencies": {
    "better-sqlite3":    "^9.6.0",
    "dotenv":            "^16.4.5",
    "exceljs":           "^4.4.0",
    "express":           "^4.19.2",
    "express-rate-limit":"^7.3.1",
    "express-validator": "^7.2.0",
    "helmet":            "^7.1.0",
    "multer":            "^1.4.5-lts.1",
    "uuid":              "^11.0.0",
    "web-push":          "^3.6.7",
    "zod":               "^3.23.8"
  },
  "devDependencies": {
    "eslint":            "^9.6.0",
    "nodemon":           "^3.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
